# vim: set ft=toml:
{{ $ephemeral := false -}}
{{- $personal := false -}}

{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS_IPC") (eq .chezmoi.username "root" "runner" "ubuntu" "vscode") -}}
{{-   $ephemeral = true -}}
{{- end -}}

{{- if eq .chezmoi.username "h3y6e" -}}
{{-   $personal = true -}}
{{- end -}}

[data]
  ephemeral = {{ $ephemeral }}
  personal = {{ $personal }}
  work = {{ and (not $ephemeral) (not $personal) }}

[data.xdg]
  config = "{{ .chezmoi.homeDir }}/.config"
  cache = "{{ .chezmoi.homeDir }}/.cache"
  data = "{{ .chezmoi.homeDir }}/.local/share"
  state = "{{ .chezmoi.homeDir }}/.local/state"

[onepassword]
  cache = true

[env]
  OP_ACCOUNT = "my.1password.com"
