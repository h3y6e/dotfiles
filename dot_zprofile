# vim: set ft=zsh:

# homebrew
type brew &>/dev/null && eval "$(brew shellenv)"

# mysql-client
[[ -d "${HOMEBREW_PREFIX}/opt/mysql-client" ]] && path=(${HOMEBREW_PREFIX}/opt/mysql-client/bin $path)

# rust
[[ -d "$HOME/.cargo" ]] && . "$HOME/.cargo/env"

# mise
type mise &>/dev/null && eval "$(mise activate zsh --shims)"

# pub
path=($HOME/.pub-cache/bin $path)

# android
path=($HOME/Library/Android/sdk/platform-tools $path)

# bun
path=($XDG_CACHE_HOME/.bun/bin $path)
