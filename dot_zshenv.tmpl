# vim: set ft=zsh:
typeset -gU cdpath fpath mailpath path

#==============================================================================
# XDG Base Directory
#==============================================================================
[[ -z "$XDG_CONFIG_HOME" ]] && export XDG_CONFIG_HOME="$HOME/.config"
[[ -z "$XDG_CACHE_HOME" ]] && export XDG_CACHE_HOME="$HOME/.cache"
[[ -z "$XDG_DATA_HOME" ]] && export XDG_DATA_HOME="$HOME/.local/share"
[[ -z "$XDG_STATE_HOME" ]] && export XDG_STATE_HOME="$HOME/.local/state"

#==============================================================================
# Environment Variables
#==============================================================================
# editors
export EDITOR='vim'
export VISUAL='vim'
export PAGER='less'

# language
export LANG='en_US.UTF-8'

{{ if eq .chezmoi.os "darwin" -}}
# browser
export BROWSER='open'
{{- end }}

# less
export LESS='-F -g -i -M -R -S -w -X -z-4'

# opencode
export OPENCODE_EXPERIMENTAL_LSP_TOOL=1
export OPENCODE_ENABLE_EXA=1

# ni.zsh
export NI_USE_SOCKET_FIREWALL=1

# telemetry
export DO_NOT_TRACK=1
export NEXT_TELEMETRY_DISABLED=1
export STORYBOOK_DISABLE_TELEMETRY=1
export EXPO_NO_TELEMETRY=1

#==============================================================================
# Path Settings
#==============================================================================
{{ if eq .chezmoi.os "darwin" -}}
# homebrew
if [[ $(arch) == "i386" ]]; then
  [ -s "/usr/local/bin/brew" ] && eval "$(/usr/local/bin/brew shellenv)"
else
  [ -s "/opt/homebrew/bin/brew" ] && eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# obsidian cli
export PATH="$PATH:/Applications/Obsidian.app/Contents/MacOS"

# mysql-client
[[ -d "${HOMEBREW_PREFIX}/opt/mysql-client" ]] && export PATH="${HOMEBREW_PREFIX}/opt/mysql-client/bin:$PATH"
{{- end }}

# rust
[[ -d "$HOME/.cargo" ]] && . "$HOME/.cargo/env"

# mise
type mise &>/dev/null && eval "$(mise activate zsh)"

# android
export PATH="$PATH:$HOME/Library/Android/sdk/platform-tools"

# pub
path=($HOME/.pub-cache/bin $path)

# maestro
export PATH="$PATH:$HOME/.maestro/bin"
