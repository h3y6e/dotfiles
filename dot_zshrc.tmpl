# vim: set ft=zsh:

### start profiler
zmodload zsh/zprof

#==============================================================================
# Zsh Options
#==============================================================================
# comment
setopt INTERACTIVE_COMMENTS

# history
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_ALLOW_CLOBBER
setopt HIST_IGNORE_SPACE
setopt HIST_NO_FUNCTIONS
setopt HIST_NO_STORE
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY

# directory
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT
setopt PUSHD_TO_HOME
setopt CDABLE_VARS
setopt MULTIOS
setopt EXTENDED_GLOB
unsetopt CLOBBER

# auto correction
setopt CORRECT

#==============================================================================
# Completions
#==============================================================================
# fpath
[[ -n "$HOMEBREW_PREFIX" ]] && FPATH="${HOMEBREW_PREFIX}/share/zsh/site-functions:${FPATH}"
[[ -d $HOME/.zfunc ]] && fpath+=$HOME/.zfunc

# compinit
autoload -Uz compinit
if [ "$(date +'%j')" != "$(stat -f '%Sm' -t '%j' ${ZDOTDIR:-$HOME}/.zcompdump)" ]; then
  compinit
else
  compinit -C
fi
autoload -U +X bashcompinit && bashcompinit

# flutter
[[ -f "$XDG_CONFIG_HOME/.dart-cli-completion/zsh-config.zsh" ]] && . "$XDG_CONFIG_HOME/.dart-cli-completion/zsh-config.zsh" || true

# gcloud
if [[ -n "$HOMEBREW_PREFIX" ]] && type gcloud &>/dev/null; then
  source "${HOMEBREW_PREFIX}/share/google-cloud-sdk/path.zsh.inc"
  source "${HOMEBREW_PREFIX}/share/google-cloud-sdk/completion.zsh.inc"
fi

# git-wt
type git-wt &>/dev/null && eval "$(git-wt --init zsh)"

#==============================================================================
# Plugins
#==============================================================================
# sheldon
type sheldon &>/dev/null && eval "$(sheldon source)"

# direnv
type direnv &>/dev/null && eval "$(direnv hook zsh)"

# 1password cli
[[ -f "$XDG_CONFIG_HOME/op/plugins.sh" ]] && source "$XDG_CONFIG_HOME/op/plugins.sh"

#==============================================================================
# Hooks
#==============================================================================
# flutter/fvm
function check-fvm() {
  if [[ -d ".fvm" ]]; then
    alias flutter='fvm flutter'
    alias dart='fvm dart'
  fi
}

autoload -Uz add-zsh-hook
add-zsh-hook chpwd check-fvm

#==============================================================================
# Aliases & Functions
#==============================================================================
# nocorrect
alias cd='nocorrect cd'
alias cp='nocorrect cp'
alias grep='nocorrect grep'
alias ln='nocorrect ln'
alias man='nocorrect man'
alias mkdir='nocorrect mkdir -p'
alias mv='nocorrect mv'
alias rm='nocorrect rm'
alias sudo='nocorrect sudo'

# ls
{{ if eq .chezmoi.os "darwin" -}}
alias ls='ls -G'
{{- else }}
alias ls='ls --color=auto'
{{- end }}
alias l='ls -A'
alias ll='ls -lh'
alias la='ll -A'
alias sl='ls'

# ghq
if type ghq &>/dev/null && type peco &>/dev/null; then
  function g() {
    local dir="$(ghq list | peco)"
    [ ! -z $dir ] && cd "$(ghq root)/$dir"
  }
fi

# git-wt
alias gw='git wt $(git wt | tail -n +2 | peco | awk "{print \$(NF-1)}")'

# Socket Firewall
alias npx='sfw npx'
alias pnpx='sfw pnpx'
alias bunx='sfw bunx'

# chezmoi
alias cz='chezmoi'
alias czz='zed $(cz source-path)'

# code
function c() {
  local editor=""
  for e in {{ if .personal }}cursor code{{ else }}code cursor{{ end }}; do
    if type $e &>/dev/null; then
      editor=$e
      break
    fi
  done

  if [ -z "$editor" ]; then
    echo "editor not found"
    return 1
  fi

  if [ -f "local.code-workspace" ]; then
    $editor -n "local.code-workspace"
  else
    local wsfile=$(find . -maxdepth 1 -type f -name "*.code-workspace" | head -n 1)
    if [ ! -z "$wsfile" ]; then
      $editor -n "$wsfile"
    else
      $editor -n .
    fi
  fi
}

# zed
alias z='zed .'

# nvim
alias n='nvim .'

# opencode
alias oc='opencode -c'

{{ if .work -}}
# copilot cli
export OTEL_EXPORTER_OTLP_ENDPOINT='{{ onepasswordRead "op://env/ai-agent-stats/endpoint" }}'
export OTEL_EXPORTER_OTLP_HEADERS='Authorization=Bearer {{ onepasswordRead "op://env/ai-agent-stats/token" }}'
{{- end }}

{{ if eq .chezmoi.os "darwin" -}}
# xcode
alias xcode='xed'
alias xcodeclean='rm -rf ~/Library/Developer/Xcode/DerivedData'

# network
alias ipen0='ipconfig getifaddr en0'

# tailscale
alias tailscale='/Applications/Tailscale.app/Contents/MacOS/Tailscale'
{{- end }}

### end profiler
zprof | head -7
