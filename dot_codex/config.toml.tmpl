# vim: set ft=toml:
#:schema https://developers.openai.com/codex/config-schema.json

model = "gpt-5.5"
model_provider = "openai"
model_reasoning_effort = "xhigh"
model_reasoning_summary = "detailed"
model_verbosity = "high"
model_supports_reasoning_summaries = true
approval_policy = "on-request"
sandbox_mode = "workspace-write"
hide_agent_reasoning = false
file_opener = "none"
web_search = "live"
suppress_unstable_features_warning = true
personality = "pragmatic"
service_tier = "fast"
plan_mode_reasoning_effort = "xhigh"
approvals_reviewer = "guardian_subagent"

[sandbox_workspace_write]
network_access = true
writable_roots = ["{{ .chezmoi.homeDir }}/ghq"]

[features]
apply_patch_freeform = true
child_agents_md = true
undo = true
codex_git_commit = true
memories = true
prevent_idle_sleep = true
guardian_approval = true
enable_fanout = true
multi_agent_v2 = true
codex_hooks = true
exec_permission_approvals = true
request_permissions_tool = true
realtime_conversation = true

[shell_environment_policy]
inherit = "all"
ignore_default_excludes = true

[agents]
max_threads = 6
max_depth = 1

[mcp_servers.figma]
url = "http://127.0.0.1:3845/mcp"

[mcp_servers.context7]
url = "https://mcp.context7.com/mcp"
{{- if not .ephemeral }}
http_headers = { "CONTEXT7_API_KEY" = "{{ onepasswordRead "op://env/context7/api-key" }}" }
{{- end }}

[mcp_servers.gh_grep]
url = "https://mcp.grep.app"

{{ if .work -}}
[otel]
environment = "prod"

[otel.metrics_exporter.otlp-http]
endpoint = "{{ onepasswordRead "op://env/ai-agent-stats/endpoint" }}/v1/metrics"
protocol = "binary"

[otel.metrics_exporter.otlp-http.headers]
Authorization = "Bearer {{ onepasswordRead "op://env/ai-agent-stats/token" }}"
{{- end }}

{{- if lookPath "ghq" }}
{{- range (output "ghq" "list" "-p" | splitList "\n") }}
{{- if ne . "" }}

[projects."{{ . }}"]
trust_level = "trusted"
{{- end }}
{{- end }}
{{- end }}
