prefix_rule(
    pattern = ["git", "commit"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "add"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "branch"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "branch", ["-d", "-D", "--delete"]],
    decision = "prompt",
)

prefix_rule(
    pattern = ["git", "checkout"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "fetch"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "push", ["--force", "--force-with-lease", "-f"]],
    decision = "prompt",
)

prefix_rule(
    pattern = ["git", "switch"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "wt", ["ls", "list"]],
    decision = "forbidden",
)

prefix_rule(
    pattern = ["git", "wt"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "wt", "-D"],
    decision = "prompt",
)

prefix_rule(
    pattern = ["git", "worktree", "add"],
    decision = "allow",
)
