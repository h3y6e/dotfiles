{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "permission": {
    "bash": {
      "*": "ask",
      "mkdir *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "sort *": "allow",
      "rg *": "allow",
      "wc *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "jq *": "allow",
      "file *": "allow",
      "which *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "realpath *": "allow",
      "readlink *": "allow",
      "pwd": "allow",
      "env": "allow",
      "printenv *": "allow",
      "date *": "allow",
      "uname *": "allow",
      "id": "allow",
      "whoami": "allow",
      "hostname": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "tree *": "allow",
      "tee *": "allow",
      "xargs *": "allow",
      "comm *": "allow",
      "paste *": "allow",
      "column *": "allow",
      "rev *": "allow",
      "fmt *": "allow",
      "expand *": "allow",
      "unexpand *": "allow",
      "md5sum *": "allow",
      "shasum *": "allow",
      "sha256sum *": "allow",
      "bat *": "allow",
      "fd *": "allow",
      "fzf *": "allow",
      "yq *": "allow",
      "actionlint *": "allow",
      "shfmt *": "allow",
      "shellcheck *": "allow",
      "mise list *": "allow",
      "mise current *": "allow",
      "mise ls *": "allow",
      "mise where *": "allow",
      "mise which *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git rev-parse *": "allow",
      "git remote *": "allow",
      "git tag *": "allow",
      "git blame *": "allow",
      "git stash list *": "allow",
      "git stash show *": "allow",
      "git shortlog *": "allow",
      "git describe *": "allow",
      "git symbolic-ref *": "allow",
      "git ls-files *": "allow",
      "git ls-tree *": "allow",
      "git ls-remote *": "allow",
      "git cat-file *": "allow",
      "git rev-list *": "allow",
      "git name-rev *": "allow",
      "git config --get *": "allow",
      "git config --list *": "allow",
      "git reflog *": "allow",
      "git count-objects *": "allow",
      "git add *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "trash *": "allow",
      "echo *": "allow",
      "touch *": "allow",
      "diff *": "allow",
      "obsidian *": "allow",
      "gh pr view *": "allow",
      "gh pr list *": "allow",
      "gh pr status *": "allow",
      "gh pr diff *": "allow",
      "gh pr checks *": "allow",
      "gh issue view *": "allow",
      "gh issue list *": "allow",
      "gh issue status *": "allow",
      "gh repo view *": "allow",
      "gh repo list *": "allow",
      "gh run view *": "allow",
      "gh run list *": "allow",
      "gh workflow view *": "allow",
      "gh workflow list *": "allow",
      "gh release view *": "allow",
      "gh release list *": "allow",
      "gh search *": "allow",
      "git add .": "deny",
      "git add -A": "deny",
      "git add -A *": "deny",
      "git add --all": "deny",
      "git add --all *": "deny",
      "rm *": "deny",
      "sudo *": "deny",
      "npx *": "deny",
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
    },
    "external_directory": {
      "~/.local/share/chezmoi/**": "allow",
      "~/ghq/**": "allow",
      "/tmp/**": "allow",
    },
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      {{- if not .ephemeral }}
      "headers": {
        "CONTEXT7_API_KEY": "{{ onepasswordRead "op://env/context7/api-key" }}",
      },
      {{- end }}
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
  },
}
