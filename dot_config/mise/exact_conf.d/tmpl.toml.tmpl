# vim: set ft=toml:
#:schema https://mise.jdx.dev/schema/mise.json

[settings]
trusted_config_paths = ["{{ .chezmoi.workingTree }}", "~/ghq"]

{{ $ollama := joinPath .xdg.data "mise/installs/ollama/latest/ollama" -}}
{{ if stat $ollama -}}
[bootstrap.macos.launchd.agents.ollama]
program = "{{ $ollama }}"
args = ["serve"]
run_at_load = true
keep_alive = true
{{- end }}

{{ if .personal -}}
[tools]
"pipx:hermes-agent" = { version = "latest", extras = "messaging" }
{{- end }}
