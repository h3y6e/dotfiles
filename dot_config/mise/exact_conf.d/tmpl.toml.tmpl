# vim: set ft=toml:
#:schema https://mise.jdx.dev/schema/mise.json

{{ $ollama := joinPath .chezmoi.homeDir ".local/share/mise/installs/ollama/latest/ollama" -}}
{{ if stat $ollama -}}
[bootstrap.macos.launchd.agents.ollama]
program = "{{ $ollama }}"
args = ["serve"]
run_at_load = true
keep_alive = true
kickstart = true
{{- end }}

{{ if .personal -}}
[tools]
pi = "latest"
"pipx:hermes-agent" = { version = "latest", extras = "messaging" }
{{- end }}
