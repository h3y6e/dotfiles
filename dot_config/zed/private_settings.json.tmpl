{
  "language_models": {
    "opencode": {
      "show_zen_models": false,
    }
  },
  "cli_default_open_behavior": "existing_window",
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "Copilot": {
      "default_config_options": {
        "allow_all": "on",
        "model": "auto",
      },
      "type": "custom",
      "command": "copilot",
      "args": ["--acp", "--stdio"],
    },
    "OpenCode": {
      "default_config_options": {
        "effort": "xhigh",
        "model": "openai/gpt-5.5-fast"
      },
      "type": "custom",
      "command": "opencode",
      "args": ["acp"],
    },
  },
  "context_servers": {
    "figma": {
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": false,
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      {{- if not .ephemeral }}
      "headers": {
        "CONTEXT7_API_KEY": "{{ onepasswordRead "op://env/context7/api-key" }}",
      },
      {{- end }}
    },
    "gh_grep": {
      "url": "https://mcp.grep.app",
    },
  },
  "colorize_brackets": true,
  "title_bar": {
    "show_sign_in": false,
  },
  "git": {
    "branch_picker": {
      "show_author_name": true,
    },
    "blame": {
      "show_avatar": true,
    },
    "inline_blame": {
      "delay_ms": 100,
      "show_commit_summary": true,
    },
    "git_gutter": "tracked_files",
    "worktree_directory": "../.wt",
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
    "collapse_untracked_diff": false,
    "sort_by_path": false,
    "status_style": "label_color",
  },
  "project_panel": {
    "dock": "left",
    "hide_gitignore": false,
    "hide_root": true,
    "indent_size": 12.0,
    "entry_spacing": "standard",
  },
  "use_system_window_tabs": false,
  "preview_tabs": {
    "enabled": true,
    "enable_keep_preview_on_code_navigation": false,
    "enable_preview_from_file_finder": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "close_on_file_delete": true,
  "search": {
    "regex": false,
  },
  "vim_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "confirm_quit": true,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé"
  },
  "base_keymap": "Atom",
  "buffer_font_size": 12,
  "buffer_font_family": "UDEV Gothic 35NFLG",
  "tab_size": 2,
  "helix_mode": false,
  "outline_panel": {
    "indent_size": 12.0,
    "button": true,
    "dock": "right",
  },
  "collaboration_panel": {
    "button": false,
    "dock": "right",
  },
  "format_on_save": "on",
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
  },
  "agent": {
    "enable_feedback": false,
    "dock": "right",
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "single_file_review": false,
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "when_hidden",
    "default_model": {
      "effort": "xhigh",
      "enable_thinking": true,
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
    },
    "commit_message_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
    },
  },
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true,
      },
    },
    "vtsls": {
      "settings": {
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "tsserver": {
            "maxTsServerMemory": 16184,
          },
        },
      },
    },
  },
  "languages": {
    "Markdown": {
      "format_on_save": "off",
    },
  },
  "auto_install_extensions": {
    "biome": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "tombi": true,
    "toml": true,
  },
}
