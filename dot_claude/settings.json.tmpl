{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "0",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_TOOL_SEARCH": "1"
  },
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(test:*)",
      "Bash(mv:*)",
      "Bash(trash:*)",
      "Bash(obsidian:*)",
      "Bash(file:*)",
      "Bash(sed:*)",
      "Bash(touch:*)",
      "Bash(diff:*)",
      "Bash(cp:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(actionlint:*)",
      "Bash(xargs grep:*)",
      "Bash(xargs wc:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm check:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm fmt:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm type-check:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm test run:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm run type-check:*)",
      "Bash(pnpm run check:*)",
      "Bash(pnpm run lint:*)",
      "Bash(biome:*)",
      "Bash(deno test:*)",
      "Bash(go doc:*)",
      "Bash(go test:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run view:*)",
      "Bash(gh issue view:*)",
      "Bash(git diff:*)",
      "Bash(git --no-pager diff:*)",
      "Bash(git --no-pager log:*)",
      "Bash(git merge-base:*)",
      "Bash(git ls-tree:*)",
      "Bash(git show:*)",
      "Read(~/.local/share/chezmoi/**)",
      "Read(~/ghq/**)",
      "Edit(./**)",
      "WebFetch",
      "WebSearch",
      "Write(./**)",
      "mcp__figma__get_image",
      "mcp__figma__get_code",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs"
    ],
    "deny": [
      "NotebookEdit",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(npx:*)",
      "Bash(git wt ls)",
      "Bash(git wt list)",
      "Read(**/.env)",
      "Read(**/.env.*local)",
      "Read(**/*.pem)",
      "Read(**/.ssh/**)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "{{ .chezmoi.homeDir }}/ghq"
    ]
  },
  "model": "{{ if .work }}opus[1m]{{ else }}opusplan{{ end }}",
  "disableAllHooks": true,
  "language": "ja",
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.githubusercontent.com"
      ],
      "allowLocalBinding": true,
      "allowAllUnixSockets": true
    },
    "filesystem": {
      "allowWrite": [
        "{{ .chezmoi.homeDir }}/.cache",
        "{{ .chezmoi.homeDir }}/.config/gcloud",
        "{{ .chezmoi.homeDir }}/.docker/buildx/activity",
        "{{ .chezmoi.homeDir }}/.docker/buildx/refs",
        "{{ .chezmoi.homeDir }}/.local/share/mise",
        "{{ .chezmoi.homeDir }}/.local/share/pnpm/store",
        "{{ .chezmoi.homeDir }}/.local/state",
        "{{ .chezmoi.homeDir }}/.Trash",
        "{{ .chezmoi.homeDir }}/ghq",
        "{{ .chezmoi.homeDir }}/go",
        "{{ .chezmoi.homeDir }}/Library/Caches"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "docker *"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "theme": "auto",
  "preferredNotifChannel": "auto",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
