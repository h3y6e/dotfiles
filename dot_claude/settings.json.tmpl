{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "0",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "0",
    "ENABLE_TOOL_SEARCH": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npx -y modern-web-guidance@latest *)"
    ],
    "deny": [
      "NotebookEdit",
      "Bash(rm *)",
      "Bash(dd *)",
      "Bash(su *)",
      "Bash(sudo *)",
      "Bash(npx *)",
      "Bash(git wt ls)",
      "Bash(git wt list)",
      "Bash(gh pr ready*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "{{ .chezmoi.homeDir }}/ghq"
    ]
  },
  "model": "{{ if .work }}claude-fable-5[1m]{{ else }}opusplan{{ end }}",
  "disableAllHooks": true,
  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.githubusercontent.com"
      ],
      "allowAllUnixSockets": true,
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "{{ .xdg.cache }}",
        "{{ .xdg.config }}/gcloud",
        "{{ .chezmoi.homeDir }}/.docker/buildx",
        "{{ .xdg.data }}/mise",
        "{{ .xdg.data }}/pnpm/store",
        "{{ .xdg.state }}",
        "{{ .chezmoi.homeDir }}/.npm",
        "{{ .chezmoi.homeDir }}/.Trash",
        "{{ .chezmoi.homeDir }}/ghq",
        "{{ .chezmoi.homeDir }}/go",
        "{{ .chezmoi.homeDir }}/Library/Caches"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "docker *"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "theme": "auto",
  "preferredNotifChannel": "auto",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
